<file path="frontend/src/features/bugs/components/BugComment.jsx">
import { bugsApi } from '../api/bugsApi';

function formatRelativeDate(value) {
  if (!value) return 'recently';
  const hours = Math.max(1, Math.round((Date.now() - new Date(value).getTime()) / 3600000));
  return hours < 24 ? `${hours} hours ago` : `${Math.round(hours / 24)} day ago`;
}

function BugComment({ comment, bugId }) {
    const handleDelete = async () => {
        if (!window.confirm("Esti sigur cea vrei sa stergi comentariul?")) return;

        try {
          await bugsApi.deleteComment(bugId, comment.id);
          window.location.reload(); // Refresh pentru a vedea lista actualizată
        } catch (error) {
          console.error("Eroare la stergere:", error);
          alert("Nu am putut sterge comentariul. Poate nu iti apartine?");
        }
      };

    const handleVote = async (voteType) => {
        try {
          await bugsApi.voteComment(bugId, comment.id, voteType);
          window.location.reload();
        } catch (error) {
          console.error("Eroare la votare:", error);
        }
      };

  return (
    <div className="single-comment">
      <div className="comment-votes">
          <button type="button" onClick={() => handleVote('UPVOTE')}>▲</button>
          <span>{comment?.votesCount || 0}</span>
          <button type="button" onClick={() => handleVote('DOWNVOTE')}>▼</button>
      </div>
      <div className="comment-content">
        <div className="comment-user-info">
          <strong>{comment.authorName}</strong>
          {comment.isStaff && <span className="user-label-staff">STAFF</span>}
          <span className="comment-time">{formatRelativeDate(comment.createdAt)}</span>
        </div>

        <p>{comment?.text || comment?.comment}</p>

        <div className="comment-footer-links">
          <button className="link-btn" type="button">Reply</button>
          <button className="link-btn" type="button" onClick={handleDelete} style={{color: 'red'}}>
              Delete
          </button>
        </div>
      </div>
    </div>
  );
}

export default BugComment;
</file>

