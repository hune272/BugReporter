    @BeforeEach
    void setUp() {
        tag = new Tag();
        tag.setId(1L);
        tag.setName("backend");
    }

    @Test
    void findAll() {
        when(tagRepository.findAll()).thenReturn(List.of(tag));
        List<TagSummary> result = tagService.findAllTags();
        assertNotNull(result);
